# PostgreSQL
POSTGRES_DB=waste_kpi
POSTGRES_USER=waste_user
POSTGRES_PASSWORD=changeme_db_password

# API
JWT_SECRET=changeme_jwt_secret_minimum_32_chars_long
API_PORT=4000
NODE_ENV=production

# Admin credentials (seeded on first run)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# External hostname used for redirects (no scheme, no trailing slash)
# When accessed through a reverse proxy, set this to your real domain.
# Examples:
#   REAL_HOST=decamp-test.dhitechnical.com
#   REAL_HOST=wastekpi.example.com
#   REAL_HOST=localhost:3300   <-- default (direct access)
REAL_HOST=decamp-test.dhitechnical.com
